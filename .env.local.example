# Copy to .env.local and fill in from Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Anthropic API key — for AI helper features (對話記錄 / 路徑規劃)
# 申請:https://console.anthropic.com
# ⚠️ 只在 server 端用(API Routes),不加 NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API key — for Whisper voice-to-text (心智圖手機版語音輸入)
# 申請:https://platform.openai.com/api-keys
# Whisper-1 約 $0.006/分鐘,儲值 $10 夠用半年以上
# ⚠️ 只在 server 端用,不加 NEXT_PUBLIC_
OPENAI_API_KEY=sk-...

# Resend — for 每週日 09:00 寄 pipeline 週報給 Admin + Team Lead(Sprint D)
# 申請:https://resend.com
RESEND_API_KEY=re_...
# 寄件人(預設用 Resend 沙箱,之後驗證 wsgfo.com 後改成 reports@wsgfo.com)
RESEND_FROM_ADDRESS=WORLDSUN Pipeline <onboarding@resend.dev>
# 收件人 reply 會到這個信箱
RESEND_REPLY_TO=hughlee@wsgfo.com

# Vercel Cron secret(在 Vercel Project Settings → Environment Variables 自動產生時複製)
CRON_SECRET=vercel_cron_secret_xxx

# Supabase Service Role(讓 cron job 繞 RLS 取完整資料,建議設)
# 拿:Supabase → Settings → API Keys → Legacy → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Google 行事曆同步(任務指派 → 同步到行事曆)
# ============================================================
# client_id / secret = 接 Supabase Google 登入的「同一組」OAuth 2.0 用戶端,
#   在 GCP → 憑證 找得到(別新建,沿用即可)。同步時用來把 refresh token
#   換成短期 access token。前置作業:GCP 啟用 Calendar API + OAuth 同意畫面
#   加 scope https://www.googleapis.com/auth/calendar.events(設 Internal)。
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxx
# 加密 refresh token 用的對稱金鑰,32 bytes hex。產生:openssl rand -hex 32
# ⚠️ 換掉這把金鑰會讓所有已存的 token 解不開 → 使用者需重新登入授權一次。
GOOGLE_TOKEN_ENC_KEY=請填 openssl rand -hex 32 的輸出

# ============================================================
# DEMO 模式(僅「示範用」的獨立 Vercel 專案才設,正式環境絕不設)
# ============================================================
# 設了 NEXT_PUBLIC_DEMO_MODE=true 後:
#  - 完全不連 Supabase,改用內建假資料(src/lib/demo/fixtures.ts)
#  - 跳過 Google 登入,改用下方 DEMO_PASSWORD 共用密碼閘門
#  - 全站唯讀(寫入/AI 端點一律擋下)
# 正式環境「沒有」這個變數 → IS_DEMO=false → 行為 100% 不受影響。
# NEXT_PUBLIC_DEMO_MODE=true
# DEMO_PASSWORD=請設一組要給訪客的共用密碼
#
# 註:demo 不會真的連 Supabase,但 client 端建構需要非空字串,
# 故 demo 專案的 NEXT_PUBLIC_SUPABASE_URL / ANON_KEY 可填假值,例如:
#   NEXT_PUBLIC_SUPABASE_URL=https://demo.invalid
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=demo-not-used
