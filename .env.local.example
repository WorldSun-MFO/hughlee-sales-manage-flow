# Copy to .env.local and fill in from Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Anthropic API key — for AI helper features (對話記錄 / 路徑規劃)
# 申請:https://console.anthropic.com
# ⚠️ 只在 server 端用(API Routes),不加 NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API key — for Whisper voice-to-text (心智圖手機版語音輸入)
# 申請:https://platform.openai.com/api-keys
# Whisper-1 約 $0.006/分鐘,儲值 $10 夠用半年以上
# ⚠️ 只在 server 端用,不加 NEXT_PUBLIC_
OPENAI_API_KEY=sk-...

# Resend — for 每週日 09:00 寄 pipeline 週報給 Admin + Team Lead(Sprint D)
# 申請:https://resend.com
RESEND_API_KEY=re_...
# 寄件人(預設用 Resend 沙箱,之後驗證 wsgfo.com 後改成 reports@wsgfo.com)
RESEND_FROM_ADDRESS=WORLDSUN Pipeline <onboarding@resend.dev>
# 收件人 reply 會到這個信箱
RESEND_REPLY_TO=hughlee@wsgfo.com

# Vercel Cron secret(在 Vercel Project Settings → Environment Variables 自動產生時複製)
CRON_SECRET=vercel_cron_secret_xxx

# Supabase Service Role(讓 cron job 繞 RLS 取完整資料,建議設)
# 拿:Supabase → Settings → API Keys → Legacy → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...
